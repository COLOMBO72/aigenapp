{
  "name": "ai-image-app",
  "private": true,
  "scripts": {
    "dev:backend": "pnpm --filter backend dev",
    "dev:mobile": "pnpm --filter mobile start",
    "dev:website": "pnpm --filter website dev",
    "build:backend": "pnpm --filter backend build",
    "build:website": "pnpm --filter website build",
    "lint": "pnpm -r lint",
    "postinstall": "pnpm --filter @ai-image-app/shared build"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "~19.2.10"
    },
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "esbuild",
      "msgpackr-extract",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}