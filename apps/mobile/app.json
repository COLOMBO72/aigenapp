{
  "expo": {
    "name": "Velium Pictures",
    "slug": "velium-pictures",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "velium-pictures",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.velium.pictures"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#0a0a0a"
      },
      "package": "com.velium.pictures",
      "versionCode": 1,
      "permissions": [],
      "privacyPolicyUrl": "https://aigenapp-backend.vercel.app/legal/privacy"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0f5d3102-364a-49b4-be57-002ba0dc4b21"
      }
    }
  }
}
